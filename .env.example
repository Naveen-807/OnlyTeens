# ═══ Flow EVM Testnet ═══
DEMO_STRICT_MODE=true
# 32-byte secp256k1 private keys, 0x-prefixed hex
FLOW_TESTNET_PRIVATE_KEY=0x_your_flow_testnet_private_key_here
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here
GAS_FREE_RPC_URL=https://testnet.evm.nodes.onflow.org
SUBSCRIPTION_RECIPIENT_ADDRESS=0x0000000000000000000000000000000000000000

# Optional overrides (otherwise loaded from deployments.json)
NEXT_PUBLIC_ACCESS_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VAULT_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SCHEDULER_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PASSPORT_CONTRACT=0x0000000000000000000000000000000000000000

# ═══ Lit Protocol ═══
# Required for PKP minting
LIT_MINTING_KEY=0x_key_for_minting_pkps
NEXT_PUBLIC_SAFE_EXECUTOR_CID=Qm_your_ipfs_cid_here

# ═══ Phone OTP ═══
TWILIO_ACCOUNT_SID=AC_your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_API_KEY_SID=SK_your_twilio_api_key_sid
TWILIO_API_KEY_SECRET=your_twilio_api_key_secret
TWILIO_VERIFY_SERVICE_SID=VAXXXXXXXXXXXXXXXX
# Set to true only if you want to force API-key auth for Verify
TWILIO_USE_API_KEY_AUTH=false

# ═══ Zama fhEVM (Sepolia) ═══
SEPOLIA_RPC_URL=https://rpc.sepolia.org
NEXT_PUBLIC_POLICY_CONTRACT=0x0000000000000000000000000000000000000000
ZAMA_NETWORK_URL=https://devnet.zama.ai
ZAMA_GATEWAY_URL=https://gateway.sepolia.zama.ai
ZAMA_KMS_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
ZAMA_ACL_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
# 32-byte secp256k1 private key, 0x-prefixed hex
ZAMA_EVALUATOR_PRIVATE_KEY=0x_private_key_with_sepolia_eth_for_policy_calls

# ═══ Storacha ═══
STORACHA_KEY=MgYour_storacha_agent_private_key
STORACHA_PROOF=your_base64_delegation_proof

# ═══ AI ═══
OPENAI_API_KEY=sk-your-key
CLAWRENCE_MODEL=gpt-4o-mini
