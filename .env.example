# ═══ Flow EVM Testnet ═══
DEMO_STRICT_MODE=true
PROOF18_LIVE_MODE=false
PROOF18_ALLOW_DEGRADED_MODE=false
# 32-byte secp256k1 private keys, 0x-prefixed hex
FLOW_TESTNET_PRIVATE_KEY=0x_your_flow_testnet_private_key_here
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here
GAS_FREE_RPC_URL=https://testnet.evm.nodes.onflow.org
FLOW_NATIVE_SCHEDULER_ENABLED=false
SUBSCRIPTION_RECIPIENT_ADDRESS=0x000000000000000000000000000000000000dEaD

# Optional overrides (otherwise loaded from deployments.json)
NEXT_PUBLIC_ACCESS_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_VAULT_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_SCHEDULER_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_PASSPORT_CONTRACT=0x0000000000000000000000000000000000000000
ACCESS_CONTRACT=0x0000000000000000000000000000000000000000
VAULT_CONTRACT=0x0000000000000000000000000000000000000000
SCHEDULER_CONTRACT=0x0000000000000000000000000000000000000000
PASSPORT_CONTRACT=0x0000000000000000000000000000000000000000

# ═══ Lit Protocol ═══
# Required for PKP minting
LIT_MINTING_KEY=0x_key_for_minting_pkps
NEXT_PUBLIC_SAFE_EXECUTOR_CID=Qm_your_ipfs_cid_here
SAFE_EXECUTOR_CID=Qm_your_ipfs_cid_here

# ═══ Lit Chipotle ═══
CHIPOTLE_ENABLE_LIVE=false
CHIPOTLE_BASE_URL=https://datil-dev.litgateway.com
CHIPOTLE_ACCOUNT_API_KEY=
CHIPOTLE_OWNER_ADDRESS=0x0000000000000000000000000000000000000000

# ═══ Phone OTP ═══
TWILIO_ACCOUNT_SID=AC_your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_API_KEY_SID=SK_your_twilio_api_key_sid
TWILIO_API_KEY_SECRET=your_twilio_api_key_secret
TWILIO_VERIFY_SERVICE_SID=VAXXXXXXXXXXXXXXXX
# Set to true only if you want to force API-key auth for Verify
TWILIO_USE_API_KEY_AUTH=false

# ═══ Zama fhEVM (Sepolia) ═══
SEPOLIA_RPC_URL=https://rpc.sepolia.org
NEXT_PUBLIC_POLICY_CONTRACT=0x0000000000000000000000000000000000000000
POLICY_CONTRACT=0x0000000000000000000000000000000000000000
ZAMA_NETWORK_URL=https://devnet.zama.ai
ZAMA_GATEWAY_URL=https://relayer.testnet.zama.org
ZAMA_KMS_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
ZAMA_ACL_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
# 32-byte secp256k1 private key, 0x-prefixed hex
ZAMA_EVALUATOR_PRIVATE_KEY=0x_private_key_with_sepolia_eth_for_policy_calls
ZAMA_PRIVATE_KEY=


# ═══ AI ═══
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
CALMA_MODEL=meta-llama/llama-3.2-3b-instruct:free
CLAWRENCE_MODEL=meta-llama/llama-3.2-3b-instruct:free

# ═══ WebAuthn (optional) ═══
NEXT_PUBLIC_APP_NAME=Proof18
NEXT_PUBLIC_WEBAUTHN_ORIGIN=http://localhost:3000
NEXT_PUBLIC_WEBAUTHN_RP_ID=localhost

# ═══ Vincent API (AI Agent Guardrails) ═══
VINCENT_API_KEY=ssk_your_vincent_api_key
VINCENT_APP_ID=app_your_vincent_app_id
VINCENT_APP_VERSION=v1
VINCENT_REDIRECT_URI=http://localhost:3000/api/vincent/auth/callback
VINCENT_JWT_AUDIENCE=proof18-calma
# Optional: only needed for delegated Vincent auth flows
# VINCENT_DELEGATEE_PRIVATE_KEY=0x_delegatee_private_key
VINCENT_ALLOWED_ACTION_TYPES=savings,subscription
VINCENT_ALLOWED_CHAINS=flow-testnet
VINCENT_ALLOWED_RECIPIENTS=
VINCENT_MAX_SINGLE_TRANSFER_FLOW=25
VINCENT_MAX_RECURRING_TRANSFER_FLOW=10

# ═══ ERC-8004 ═══
ERC8004_CHAIN_ID=11155111
CALMA_OPERATOR_PRIVATE_KEY=0x_private_key_for_calma_agent_identity
ERC8004_IDENTITY_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
ERC8004_REPUTATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
ERC8004_VALIDATION_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
CALMA_AGENT_URI_BASE=http://localhost:3000/api

# ═══ Demo / utility scripts (optional) ═══
DEMO_GUARDIAN_ADDRESS=
DEMO_TEEN_ADDRESS=
DEMO_EXECUTOR_ADDRESS=
FAMILY_LABEL=proof18-demo
ACCESS_CONTRACT_SEPOLIA=
POLICY_ACCESS_CONTRACT=
